# ==============================================================
# vm-platform – Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file to version control.
# ==============================================================

# ---------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------
# Used by Drizzle and internal DB clients
DATABASE_URL=postgresql://admin:password@db:5432/vm_platform
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me
POSTGRES_DB=vm_platform

# ---------------------------------------------------------------
# Supabase – Infrastructure
# ---------------------------------------------------------------
# Server-side (never expose to the browser)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---------------------------------------------------------------
# Auth & Security
# ---------------------------------------------------------------
# JWT secret used by legacy shared components or security layers
JWT_SECRET=
# Used to validate cron jobs or internal system triggers
CRON_SECRET=

# ---------------------------------------------------------------
# App URLs – used for cross-app redirects and API calls
# ---------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000/dashboard
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---------------------------------------------------------------
# API / NestJS
# ---------------------------------------------------------------
PORT=4000
CORS_ORIGIN=http://localhost:3000
SUPABASE_JWKS_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co/auth/v1/jwks.json

# ---------------------------------------------------------------
# External Services
# ---------------------------------------------------------------
# Upstash Redis - Serverless Rate Limiting
UPSTASH_REDIS_REST_URL=https://xxxxxxxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Resend - Email Delivery
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=no-reply@zonasurtech.online

# AI - Google Gemini
GOOGLE_GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXX

# ---------------------------------------------------------------
# System Config
# ---------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
