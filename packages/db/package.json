{
  "name": "@repo/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./cms-schema": {
      "types": "./src/cms-schema.ts",
      "default": "./dist/cms-schema.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
